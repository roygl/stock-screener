# Streamlit secrets — optional LLM API keys for the natural-language search.
#
# The screener is OFFLINE-FIRST: with no key it uses the rule-based parser and
# works fully. A key here only enables the LLM-backed "Ask in plain English" box.
#
# Setup:
#   1. Copy this file to `.streamlit/secrets.toml` (same folder, drop ".example").
#   2. Uncomment and fill in the ONE key for the provider you select in the sidebar.
#   3. `pip install openai` (or `anthropic` for the Anthropic provider).
#   4. Restart the app — the sidebar shows "✓ LLM-backed (...)".
#
# `.streamlit/secrets.toml` is gitignored, so your key is never committed. These
# values are also read from real environment variables of the same name; an
# environment variable WINS over the value here.

# Anthropic (Claude)
# ANTHROPIC_API_KEY = "sk-ant-..."

# OpenAI (GPT)
# OPENAI_API_KEY = "sk-..."

# xAI (Grok)
# XAI_API_KEY = "xai-..."

# Google (Gemini) — GEMINI_API_KEY is primary; GOOGLE_API_KEY is also accepted.
# GEMINI_API_KEY = "AIza..."
# GOOGLE_API_KEY = "AIza..."

# Mistral
# MISTRAL_API_KEY = "..."

# Ollama (local) needs no key — just run the server and select it in the sidebar.
